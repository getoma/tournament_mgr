{% import 'base/match.twig' as part %}

{% include 'base/header.twig' with {
  'active_page': 'tournaments.areas.dashboard.show',
  'css': ['tree.css'],
  'header': area.name,
} %}

{% for category in categories -%}
<section>
  <h2>{{ category.name }}</h2>

  {% for section, matches in match_lists[category.id] -%}
  <section>
  <h3>{{ section }}</h3>
    <ul>
    {% for node in matches -%}
    <li>{{part.printMatch(node)}}</li>
    {%- endfor %}
    </ul>
  </section>
  {% endfor %}
</section>
{% endfor %}

{% include 'base/footer.twig' %}