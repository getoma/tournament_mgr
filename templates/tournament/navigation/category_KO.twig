{% import 'base/form.twig' as form %}
{% import 'base/match.twig' as part %}

{%- include 'base/header.twig' with {
  'active_page': 'tournaments.categories.ko.show',
  'css': ['tree.css']
} %}

<section>
<h2>{{ route_context.category.name }} - KO-Runde</h2>
<nav class="ko-full-tree">
{{ part.printKo(ko_rounds, 'tournaments.categories.ko.matches.show', route_context.args) }}
</nav>
</section>

{% if change_log is not empty -%}
<section class="change_log">
  <h2>Änderungen</h2>
  <table class="change_log">
    <thead>
      <tr>
        <th>Änderung</th>
        <th>Details</th>
      </tr>
    </thead>
    <tbody>
      {% for entry in change_log -%}
      <tr>
        <td>{{ entry.change_type }}</td>
        {% if entry.change_type == 'rename' %}
        <td><del>{{entry.details['from']}}</del> <ins>{{ entry.details['to'] }}</ins></td>
        {% else %}
        <td>{{ entry.details['participant'].getDisplayName() }}
        {%- if entry.details['from'] is not empty %} <del>{{entry.details['from']|humanizeSlotName}}</del>{% endif -%}
        {%- if entry.details['slot_name'] is not empty %} <ins>{{ entry.details['slot_name']|humanizeSlotName }}</ins>{% endif -%}
        </td>
        {% endif -%}
      </tr>
      {%- endfor %}
    </tbody>
  </table>
</section>
{%- endif %}

{% if no_pools %}

{% if unmapped_participants is not empty %}
<section>
  <h2>Nicht zugewiesen</h2>
  <ul>
    {% for p in unmapped_participants %}
    <li>{{p.getDisplayName()}}</li>
    {% endfor %}
  </ul>
  <form action="{{url_for('tournaments.categories.assignParticipants', route_context.args)}}" method="post">
  {{ form.submit('Diese Teilnehmer einsortieren')}}
  </form>
</section>
{% endif %}

{% if policy.isActionAllowed('ManageSetup') %}
<section>
<form action="{{url_for('tournaments.categories.shuffleParticipants', route_context.args)}}" method="post">
{{ form.submit('Teilnehmer neu verteilen', confirm="Wirklich alle Teilnehmer neu verteilen?")}}
</form>
</section>
{% endif %}

{% endif %}

{% include 'base/footer.twig' %}
