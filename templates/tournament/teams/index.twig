{% import 'base/form.twig' as form %}

{%- include 'base/header.twig' with { 'active_page': 'tournaments.categories.teams.index' } %}

<section>
  <h2>Teams</h2>
  {% if prg_message.status == 'removed' -%}
  <p class="ok">Team {{ prg_message.team }} wurde gelöscht.</p>
  {%- endif %}
  <table id="team_list">
    <thead>
      <tr>
        <th>Team-Name</th>
        <th colspan="{{route_context.category.config.team_size}}">Team-Mitglieder</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      {% for team in teams -%}
      <tr>
        {% set team_url = url_for('tournaments.categories.teams.show', route_context.args|merge({teamId: team.id})) %}
        <td>{{ team.getDisplayName()|wrap_if(team.withdrawn, 'del') }}</td>
        {%- for member in team.members -%}
        <td>{{ member.getDisplayName() }}</td>
        {%- endfor -%}
        {% if team.members.count() < route_context.category.config.team_size %}
          {%- for i in range(team.members.count(), route_context.category.config.team_size - 1, 1) -%}
        <td><a href="{{ team_url }}"> </a></td>
          {%- endfor -%}
        {%- endif %}
        <td>
          <a href="{{ url_for('tournaments.categories.teams.show', route_context.args|merge({teamId: team.id})) }}"
            class="form-btn">{{ policy.isActionAllowed('ModifyParticipants')? "Bearbeiten" : "Details" }}</a>
          {% if policy.isActionAllowed('DeleteParticipants') -%}
          <form method="POST" action="{{ url_for('tournaments.categories.teams.delete', route_context.args|merge({teamId: team.id})) }}">
            <input type="hidden" name="_METHOD" value="DELETE">
            {{ form.submit('Löschen', confirm='Team %s wirklich löschen?'|format(team.getDisplayName())) }}
          </form>
          {%- endif %}
        </td>
      </tr>
    {%- endfor %}
    </tbody>
  </table>
  <p>
    <a href="{{ url_for('tournaments.categories.teams.create', route_context.args) }}" class="form-btn">Team anlegen</a>
  </p>
</section>

{% include 'base/footer.twig' %}

