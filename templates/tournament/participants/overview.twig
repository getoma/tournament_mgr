{% import 'base/form.twig' as form %}

{%- include 'base/header.twig' with { 'active_page': 'tournaments.participants.index' } %}

<section>
  <h2>Teilnehmer</h2>
{% if prg_message -%}
{% set message_dict = {
  'updated':  "Teilnehmerliste erfolgreich aktualisiert!",
  'imported': "Teilnehmer erfolgreich importiert!",
  'deleted':  "Teilnehmer wurde gelöscht."
} %}
  <p class="ok">{{ message_dict[prg_message.status]|default("Teilnehmerliste erfolgreich aktualisiert!") }}</p>
  {% if prg_message.duplicates is not empty -%}
  <p class="warning">Teilnehmer bereits erfasst und nicht neu importiert:</p>
  <ul id="duplicate_participant_list" class="warning">
    {% for participant in prg_message.duplicates %}
    <li>{{participant.lastname}}, {{participant.firstname}} {%if participant.club%}({{participant.club}}){%endif%}</li>
    {% endfor %}
  </ul>
  {%- endif %}
{%- endif %}
{% if errors -%}
  {% if errors.input_error %}<p class="error">Teilnehmer konnten nicht importiert werden, bitte Eingaben überprüfen</p>{% endif -%}
  {% if errors.sql_error %}<p class="error">{{errors.sql_error}}</p>{% endif -%}
{% endif -%}
{%- set assignments_needed = false %}

  <table id="participants_list">
    <thead>
      <tr>
        <th>Teilnehmer</th>
        <th title="Teilnehmer aus dem selben Verband oder Verein werden bei Auslosung möglichst weit voneinander entfernt platziert.">Verband/Verein</th>
        {% for category in categories -%}
        <th class="checkbox">{{ category.name }}</th>
        {% endfor -%}
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      {% for participant in participants %}
      <tr>
        <td>{{ participant.lastname }}, {{ participant.firstname }}</td>
        <td>{{ participant.club }} </td>
        {% for category in categories -%}
        <td class="checkbox">
          {%  if participant.categories[category.id] is defined %}
          <span class="checkmark">X</span>
            {%- set preset, assigned =
                    participant.categories[category.id].pre_assign? starting_slots[category.id][participant.categories[category.id].pre_assign] : '',
                    participant.categories[category.id].slot_name|humanizeSlotName %}
            {%- set slot = assigned|default(preset)|default('') %}
            {%- set slot_issue = preset is not empty and slot != preset %}
            {%- if slot is not empty %}
            <span class="participant-assigned-slot{% if preset is not empty %} participant-preassigned-slot{% endif %}"
              {%- if slot_issue %} title="Aktuelle Startposition weicht von vorgegebenem Start in {{ preset }} ab"
              {%- elseif preset is not empty %} title="Startposition vorgegeben"{% endif %}>
              {%- if slot_issue %}<del>{{preset}}</del>{% endif -%}
              ({{ slot }})</span>
            {%- else -%}
              {% set assignments_needed = true %}
            {%- endif %}
          {%- endif %}
        </td>
        {% endfor -%}
        <td>
          <a href="{{ url_for('tournaments.participants.show', route_context.args|merge({'participantId': participant.id})) }}"
             class="form-btn">{{ policy.isActionAllowed('ModifyParticipants')? "Bearbeiten" : "Details" }}</a>
          {% if policy.isActionAllowed('DeleteParticipants') -%}
          <form method="POST" action="{{ url_for('tournaments.participants.delete', route_context.args|merge({'participantId': participant.id})) }}">
            <input type="hidden" name="_METHOD" value="DELETE">
            {{ form.submit('Löschen', confirm='%s, %s wirklich löschen?'|format(participant.lastname, participant.firstname)) }}
          </form>
          {%- endif %}
        </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
  <div class="button-box">
  {% if policy.isActionAllowed('ModifyParticipants') -%}
  <p>
    <a href="{{ url_for('tournaments.participants.create', route_context.args)}}" class="form-btn">Teilnehmer hinzufügen</a>
  </p>
  <form method="POST" action="{{ url_for('tournaments.participants.assign', route_context.args) }}">
    {{ form.submit('Teilnehmer zuweisen', active: assignments_needed) }}
  </form>
  {%- endif %}
  {% if policy.isActionAllowed('ShuffleParticipants') -%}
  <form method="POST" action="{{ url_for('tournaments.participants.shuffle', route_context.args)}}">
    {{ form.submit('Teilnehmer neu verteilen', confirm="Wirklich alle Startpositionen neu zuweisen?") }}
  </form>
  {%- endif %}
  </div>
</section>


{% if policy.isActionAllowed('ImportParticipants') -%}
<section>
<h2>Teilnehmer importieren</h2>
<form method="POST" action="{{ url_for('tournaments.participants.import.store', { 'tournamentId': tournament.id }) }}" id="participant_upload_form" enctype="multipart/form-data">
  {{ form.input('file', 'participant_file', 'Datei (CSV oder Excel)', '', errors.file, attributes={'accept':".csv,.xlsx,.xls,.ods"}) }}
  {{ form.submit('Importieren') }}
</form>
</section>

<section>
<h2>Teilnehmer hinzufügen</h2>
  <form method="POST" action="{{ url_for('tournaments.participants.bulk.store', route_context.args) }}" id="participant_add_form">
    {{ form.textarea('participants', 'Direkteingabe', prev.participants ?? '', errors.participants, attributes={'rows':10, 'cols': 50, 'id':'participants', 'placeholder':'Vorname Nachname pro Zeile'}) }}
    {{ form.input('text', 'club', 'Verein/Verband', prev.club ?? '', errors.club, attributes={'maxlength':100}) }}
    <fieldset class="checkbox-set">
      <legend>Kategorien auswählen</legend>
      {% for category in categories -%}
      {{ form.checkbox('categories[]', category.name, category.id, category.id in prev.categories) }}
      {%- endfor %}
      {%- if errors.categories %}
      <p class="error">{{errors.categories}}</p>
      {% endif -%}
    </fieldset>
    {{ form.submit('Hinzufügen') }}
  </form>
</section>
{%- endif %}

{% include 'base/footer.twig' %}