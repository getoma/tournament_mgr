{%- include 'base/header.twig' with { 'active_page': 'tournaments.index' } %}

{% for status, tournaments in tournaments_by_state %}
<section>
  <h2>{{status}}</h2>
  <nav>
  <table id="tournament_list" class="row-links">
  <thead>
    <tr>
      <th>Datum</th>
      <th>Turnier</th>
    </tr>
  </thead>
  <tbody>
      {% for tournament in tournaments %}
      <tr>
        <td><a href="{{ url_for('tournaments.show', { tournamentId: tournament.id }) }}">{{ tournament.date }}</a></td>
        <td><a href="{{ url_for('tournaments.show', { tournamentId: tournament.id }) }}">{{ tournament.name }}</a></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  </nav>
</section>
{%endfor%}

{%- if policy.isActionAllowed('CreateTournaments') %}
<section>
  <p><a class="form-btn" href="{{url_for('tournaments.create')}}">Neues Turnier anlegen</a></p>
</section>
{%- endif -%}

{% include 'base/footer.twig' %}
