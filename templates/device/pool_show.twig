{% import 'base/form.twig' as form %}
{% import 'base/match.twig' as part %}

{%- include 'base/header.twig' with {
'active_page': 'device.categories.pools.show',
'css': ['match.css']
} %}

<section class="pool_match_list">
  <h2>Kämpfe - Pool {{pool.getName()}}</h2>

  {{ part.printMatchTable(pool.getMatchList(), selected, 'device.categories.pools.matches.update', route_context.args) }}

  {% if error -%}
  <p class="error">{{ error }}</p>
  {%- endif %}

  {% if pool.needsDecisionRound() -%}
  <form method="post" action="{{url_for('device.categories.pools.decision.add', route_context.args)}}"
    class="pool_control" id="tie_break_match_add">
    {{ form.submit('Entscheidungsrunde hinzufügen') }}
  </form>
  {% endif %}

  {% if pool.getCurrentDecisionRound() -%}
  <form method="post"
    action="{{url_for('device.categories.pools.decision.delete', route_context.args|merge({'decision_round': pool.getCurrentDecisionRound()})) }}"
    class="pool_control" id="tie_break_match_delete">
    <input type="hidden" name="_METHOD" value="DELETE">
    {{ form.submit('Letzte Entscheidungsrunde löschen') }}
  </form>
  {% endif %}

</section>

<section class="pool_ranking">
  <h2>Platzierung</h2>
  <table>
    <thead>
      <tr>
        <th>Platz</th>
        <th>Name</th>
        <th>Siege</th>
        <th>Unentschieden</th>
        <th>Punkte</th>
      </tr>
    </thead>
    <tbody>
      {% for entry in pool.getRanking() -%}
      <tr>
        <td>{{entry.rank}}</td>
        <td>{{entry.participant.lastname}}, {{entry.participant.firstname}}</td>
        <td>{{entry.wins}}</td>
        <td>{{entry.ties}}</td>
        <td>{{entry.points}}</td>
      </tr>
      {% endfor -%}
    </tbody>
  </table>
</section>

<section>
  <h2>Weiter...</h2>
  <nav class="stream-nav">
  {% if next_pool is not null -%}
  <p><a href="{{ url_for('device.categories.pools.show', route_context.args|merge({'pool': next_pool.getName()})) }}">Pool {{ next_pool.getName() }}</a></p>
  {% else %}
  <p><a href="{{ url_for('device.categories.show', route_context.args) }}">Nach oben</a></p>
  {%- endif %}
  </nav>
</section>

{% include 'base/footer.twig' %}