{% import 'base/form.twig' as form %}

{%- include 'base/header.twig' %}

<section>
  <h2>Login mit Einmal-Code</h2>

  {% if error %}
  <p class="error">Der eingegebene Code ist ungültig</p>
  {% endif %}

  <form method="post" action="{{ url_for('device.login.attempt') }}">
    {{ form.input('text', 'login_code', 'Code', prev.login_code, required=true)}}
    {{ form.submit('Anmelden')}}
  </form>

  <nav id="login_nav">
    <ul>
      <li><a href="{{ url_for('auth.login.form') }}">Zurück zum normalen Login</a></li>
    </ul>
  </nav>

</section>

{% include 'base/footer.twig' %}